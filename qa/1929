seq=`basename $0`
echo "QA output created by $seq"

. ./common.python

$python -c "from pcp import pmapi" >/dev/null 2>&1
[ $? -eq 0 ] || _notrun "python pcp pmapi module not installed"
$python -c "from collections import OrderedDict" >/dev/null 2>&1
[ $? -eq 0 ] || _notrun "python collections OrderedDict module not installed"

which pmrep >/dev/null 2>&1 || _notrun "pmrep not installed"

status=1	# failure is the default!
trap "cd $here; _cleanup; exit \$status" 0 1 2 3 15

_cleanup()
{
    rm -f $tmp.*
}

log="--archive $here/archives/dyninsts -z"
metrics="disk.dev.read disk.dev.write mem.util.free mem.util.used"

# real QA test starts here
echo "=== pmrep csv output without inst/units info"
pmrep $log -o csv -I -r -u                           --no-inst-info  $metrics

echo "=== pmrep csv output with units info"
pmrep $log -o csv -I -r -u                           --csv-unit-info $metrics

echo "=== pmrep csv output - filter without units info"
pmrep $log -o csv -I -r -u -i '.*sdb.*' -i '.*sdd.*'                 $metrics

echo "=== pmrep csv output - filter with units info"
pmrep $log -o csv -I -r -u -i '.*sdb.*' -i '.*sdd.*' --csv-unit-info $metrics

# success, all done
status=0
exit
