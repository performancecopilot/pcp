#!/bin/sh
# PCP QA Test No. 1920
# Exercise __pmtimespecParse() with negative relative time offsets
# and the PM_MAX_TIME_T sentinel — unit test for the series/values
# time parsing fix (GitHub issue #2503).
#
# Copyright (c) 2024 Red Hat.
#

seq=`basename $0`
echo "QA output created by $seq"

# get standard environment, filters and checks
. ./common.product
. ./common.filter
. ./common.check

[ -f src/series_time_parse_test ] || _notrun "src/series_time_parse_test binary not built"

_cleanup()
{
    cd $here
    $sudo rm -rf $tmp $tmp.*
}

_filter()
{
    sed \
        -e 's/now = [0-9][0-9]*/now = TIMESTAMP/' \
        -e 's/returned -\{0,1\}[0-9][0-9]*/returned RETCODE/' \
    #end
}

status=1	# failure is the default!
trap "_cleanup; exit \$status" 0 1 2 3 15

# real QA test starts here
src/series_time_parse_test | _filter

# success, all done
status=0
exit
