#!/bin/sh
#
# remake the amdgpu archive ...
# this archive is intended to be checked in and not remade, this script is
# simply a record of how it was created
#

. /etc/pcp.env

tmp="${TMPDIR:-/tmp}/`basename $0`-$$"
rm -f "$tmp".*
sts=1
trap "rm -f \"$tmp\".*; exit \$sts" 0 1 2 3 15

# see ./mk.common for shell variable definitions
#
archive=amdgpu
probe=amdgpu.gpu.temperature
samples=7
# this is ($samples-2)*logging interval (5 sec below) [in secs]
expect=5

# pmlogger configuration
#
cat <<End-of-File >>"$tmp.config"
log mandatory on once { hinv }
log mandatory on 1 sec {
    `echo $probe | sed -e 's/\..*//'`
    proc.fdinfo
}
End-of-File

. ./mk.common

rm -f amdgpu.smi.txt
if which amd-smi >/dev/null 2>&1
then
    amd-smi >$archive.smi.txt 2>"$tmp.err"
    if [ $? != 0 -o -s "$tmp.err" ]
    then
	echo >&2 "mk.amdgpu: Warning: amd-smi failed"
	cat >&2 "$tmp.err"
	rm -f "$tmp.err"
    fi
    amd-smi metric >>$archive.smi.txt 2>>"$tmp.err"
    if [ $? != 0 -o -s "$tmp.err" ]
    then
	echo >&2 "mk.amdgpu: Warning: amd-smi metric failed"
	cat >&2 "$tmp.err"
	rm -f "$tmp.err"
    fi
else
    echo >&2 "mk.amdgpu: Warning: amd-smi not installed, cannot recreate $archive.smi.txt"
fi

exit
