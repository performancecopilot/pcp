#!/bin/sh
#
# make the all-ubuntu.22.04-* subset archives from all-ubuntu.22.04 in
# ../bigarchives
#

base=all-ubuntu.22.04
here=`pwd`
status=1
tmp=/tmp/mk.all-ubuntu.22.04-$$

trap "rm -rf $tmp $tmp.*; exit \$status" 0 1 2 3 15

_fail()
{
    echo >&2 "mk.all-ubuntu.22.04: Error: $1"
    status=1
    exit
}

# subset-a: selecting a subset of the metrics and all pmResults
#
rm -f ${base}-a.*
cat <<End-of-File >$tmp.config
# metrics needed by ...
# qa/1465
ipc.shm.owner
kernel.uname.nodename
network.interface.hw_addr
network.interface.inet_addr
openmetrics.control.status
pmcd.agent.name
pmcd.client.whoami
pmcd.hostname
pmcd.pmie.configfile
pmcd.pmie.logfile
pmcd.pmie.pmcd_host
pmcd.pmlogger.archive
pmcd.pmlogger.host
pmcd.pmlogger.pmcd_host
pmda.uname
proc.id.egid_nm[1920,3233520]
proc.id.euid_nm[1920,3233520]
proc.id.fsgid_nm[1920,3233520]
proc.id.fsuid_nm[1920,3233520]
proc.id.gid_nm[1920,3233520]
proc.id.sgid_nm[1920,3233520]
proc.id.suid_nm[1920,3233520]
proc.id.uid_nm[1920,3233520]
proc.memory.maps[2981799]
proc.psinfo.cmd[2366,332881,3363]
proc.psinfo.cwd[2366,332881,3363]
proc.psinfo.environ[332881,3363]
proc.psinfo.exe[2981799]
proc.psinfo.psargs[2165,2166]
sampledso.proc.exec
sampledso.proc.ordinal
sampledso.proc.time
sample.proc.exec
sample.proc.ordinal
sample.proc.time
End-of-File
pmlogextract -c $tmp.config ../bigarchives/$base ${base}-a || _fail "pmlogextract"
pmlogcompress ${base}-a || _fail pmlogcompress
