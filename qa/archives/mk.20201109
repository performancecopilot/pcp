#!/bin/sh
#
# make the 20201109 subset archives from 20201109 in
# ../bigarchives
#
# subset-a: selecting a subset of the metrics and all pmResults
# subset-b: selecting all metrics but only the first 20 pmResults
#

base=20201109
here=`pwd`
status=1
tmp=/tmp/mk.20201109-$$

trap "rm -rf $tmp $tmp.*; exit \$status" 0 1 2 3 15

_fail()
{
    echo >&2 "mk.20201109: Error: $1"
    status=1
    exit
}

rm -f ${base}-a.*
cat <<End-of-File >$tmp.config
# metrics needed by ...
# same starting pmResult and archive label
hinv.ncpu
# qa/1298
proc.psinfo.rss
# qa/1775
proc.psinfo.utime
End-of-File
pmlogextract -c $tmp.config ../bigarchives/$base ${base}-a || _fail "pmlogextract"
pmlogcompress ${base}-a || _fail pmlogcompress

mkdir $tmp || _fail mkdir
pmlogcp ../bigarchives/$base $tmp || _fail "pmlogcp -> $tmp"
cd $tmp || _fail "cd $tmp"
pmlogdecompress $base || _fail pmlogdecompress

for part in 0
do
    offset=''
    eval `$here/../src/scandata -o $base.$part | sed -n -e '/\[21]/{
s/.* @ //
p
}'`
    [ -n "$offset" ] || _fail "scandata vol $part"
    echo "[vol $part] offset=$offset"
    truncate -s $offset $base.$part || _fail "truncate vol $part"
done

pmlogcheck -R $base || _fail pmlogrepair

cd $here || _fail "cd back"
rm -f ${base}-b.*
pmlogmv $tmp/$base ${base}-b || _fail "pmlogmv back"
pmlogcompress ${base}-b || _fail pmlogcompress

