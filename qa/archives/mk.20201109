#!/bin/sh
#
# make the 20201109 subset archives from 20201109 in
# ../bigarchives
#

base=20201109
status=1
tmp=/tmp/mk.$base-$$

trap "rm -rf $tmp $tmp.*; exit \$status" 0 1 2 3 15

. ./mk.rc

# subset-a: selecting a subset of the metrics and all pmResults
#
cat <<End-of-File >$tmp.config
# metrics needed by ...
# same starting pmResult and archive label
hinv.ncpu
# qa/1298
proc.psinfo.rss
# qa/1775
proc.psinfo.utime
End-of-File
_select_metrics ../bigarchives/$base $base-a

# subset-b: selecting all metrics but only the first 20 pmResults
#           from each data volume
#
_select_first_n 20 ../bigarchives/$base $base-b
