#!/bin/sh
#
# make the simple-nvme subset archives from simple-nvme in
# ../bigarchives
#

base=simple-nvme
status=1
tmp=/tmp/mk.$base-$$

trap "rm -rf $tmp $tmp.*; exit \$status" 0 1 2 3 15

. ./mk.rc

# subset-a: selecting a subset of the metrics and a couple of pmResults
#
cat <<End-of-File >$tmp.config
# metrics needed by ...
# preamble so archive label records match
pmcd.pmlogger.host
# qa/869 (and some more)
disk.dev.read
disk.dev.write
disk.partitions.read
disk.partitions.write
End-of-File
_select_metrics ../bigarchives/$base $base-tmp

# now just the first 2 pmResults
#
rm -f $base-a.*
pmlogextract -s 2 $base-tmp $base-a
_compress ../bigarchives/$base $base-a
rm -f $base-tmp.*
