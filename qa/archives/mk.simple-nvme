#!/bin/sh
#
# make the simple-nvme subset archives from simple-nvme in
# ../bigarchives
#

base=simple-nvme
here=`pwd`
status=1
tmp=/tmp/mk.simple-nvme-$$

trap "rm -rf $tmp $tmp.*; exit \$status" 0 1 2 3 15

_fail()
{
    echo >&2 "mk.simple-nvme: Error: $1"
    status=1
    exit
}

# subset-a: selecting a subset of the metrics and a couple of pmResults
#
rm -f ${base}-a.*
cat <<End-of-File >$tmp.config
# metrics needed by ...
# qa/869 (and some more)
disk.dev.read
disk.dev.write
disk.partitions.read
disk.partitions.write
End-of-File
pmlogextract -c $tmp.config ../bigarchives/$base ${base}-a -s 2 || _fail "pmlogextract"
pmlogcompress ${base}-a || _fail pmlogcompress
