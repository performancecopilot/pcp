#!/bin/sh
#
# make the 20180416 subset archive from 20180416.10.00 in
# ../bigarchives by selecting the first 10 pmResults in each
# archive volume
#
# the [11] selector for the scandata output is where the "10"
# comes from
#

status=1
tmp=/tmp/mk.20180416-$$

trap "rm -rf $tmp $tmp.*; exit \$status" 0 1 2 3 15

. ./mk.rc

# just first 10 pmResults from each data volume
#
_select_first_n 10 ../bigarchives/20180416.10.00 20180416
