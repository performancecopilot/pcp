#!/bin/sh
#
# make the 20130706 subset archives from 20130706 in
# ../bigarchives
#

base=20130706
here=`pwd`
status=1
tmp=/tmp/mk.$base-$$

trap "rm -rf $tmp $tmp.*; exit \$status" 0 1 2 3 15

. ./mk.rc


# subset-a: selecting a subset of the metrics and all pmResults
#
rm -f ${base}-a.*
cat <<End-of-File >$tmp.config
# metrics needed by ...
# preamble so archive label records match
pmcd.pmlogger.host
# qa/733 ...
filesys.used
filesys.capacity
kernel.all.cpu.idle
hinv.ncpu
kernel.percpu.cpu.idle
swap.pagesout
# and qa/880 ...
kernel.all.sysfork
# and qa/1069 ...
hinv.machine
hinv.map.scsi
disk.dev
network.interface.mtu
mem.util
kernel.all.load
kernel.all.sysfork
kernel.all.uptime
kernel.all.cpu.user
kernel.percpu.cpu.user
# and qa/1070 ...
hinv.cpu.clock
# and qa/1792 ...
disk.all.avactive
End-of-File
pmlogextract -c $tmp.config ../bigarchives/$base ${base}-a || _fail "pmlogextract"
pmlogcompress -f bzip2 ${base}-a.0 || _fail pmlogcompress
_report ${base} -a

if false
then
# subset-b: selecting all metrics but only the first 20 pmResults
#           from each data volume
#
mkdir $tmp || _fail mkdir
pmlogcp ../bigarchives/$base $tmp || _fail "pmlogcp -> $tmp"
cd $tmp || _fail "cd $tmp"
pmlogdecompress $base || _fail pmlogdecompress
for vol in $base.[0-9]*
do
    part=`echo "$vol" | sed -e "s;.*$base\.;;" -e 's/\..*//'`
    [ -f $base.$part ] || _fail "missing vol $vol -> $part"
    offset=''
    eval `$here/../src/scandata -o $base.$part | sed -n -e '/\[21]/{
s/.* @ //
p
}'`
    [ -n "$offset" ] || _fail "scandata vol $part"
    echo "[vol $part] offset=$offset"
    truncate -s $offset $base.$part || _fail "truncate vol $part"
done
pmlogcheck -w -R $base || _fail pmlogrepair
cd $here || _fail "cd back"
rm -f ${base}-b.*
pmlogmv $tmp/$base ${base}-b || _fail "pmlogmv back"
pmlogcompress ${base}.0-b || _fail pmlogcompress
_report $base -b
fi
