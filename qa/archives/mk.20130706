#!/bin/sh
#
# make the 20130706 subset archives from 20130706 in
# ../bigarchives
#

base=20130706
status=1
tmp=/tmp/mk.$base-$$

trap "rm -rf $tmp $tmp.*; exit \$status" 0 1 2 3 15

. ./mk.rc

# subset-a: selecting a subset of the metrics and all pmResults
#
cat <<End-of-File >$tmp.config
# metrics needed by ...
# preamble so archive label records match
pmcd.pmlogger.host
# qa/733 ...
filesys.used
filesys.capacity
kernel.all.cpu.idle
hinv.ncpu
kernel.percpu.cpu.idle
swap.pagesout
# and qa/880 ...
kernel.all.sysfork
# and qa/1069 ...
hinv.machine
hinv.map.scsi
disk.dev
network.interface.mtu
mem.util
kernel.all.load
kernel.all.sysfork
kernel.all.uptime
kernel.all.cpu.user
kernel.percpu.cpu.user
# and qa/1070 ...
hinv.cpu.clock
# and qa/1792 ...
disk.all.avactive
End-of-File

_select_metrics ../bigarchives/$base $base-a
