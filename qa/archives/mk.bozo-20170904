#!/bin/sh
#
# make the bozo-20170904-* subset archives from bozo-20170904 in
# ../bigarchives
#
# subset-a: selecting a subset of the metrics and all pmResults
# subset-b: selecting all metrics but only the first 15 pmResults
#

base=bozo-20170904
status=1
tmp=/tmp/mk.bozo-$base-$$

trap "rm -rf $tmp $tmp.*; exit \$status" 0 1 2 3 15

. ./mk.rc

# subset-a: selecting a subset of the metrics and all pmResults
#
cat <<End-of-File >$tmp.config
# metrics needed by ...
# preamble so archive label records match
pmcd.pmlogger.host
# multithread12
sample.colour
# qa/588, qa/595
kernel.percpu.cpu.user
network.interface.out.packets
# qa/1069
tape.dev.io_ns
mem.util.used
# qa/1302
sample.colour
End-of-File
_select_metrics ../bigarchives/$base $base-a

# subset-b: selecting all metrics but only the first 15 pmResults
#           from each data volume
#
_select_first_n 15 ../bigarchives/$base $base-b
