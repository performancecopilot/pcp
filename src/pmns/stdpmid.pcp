### FREE SLOTS 255...510 ###
# all of these became "free" when the domain field in a PMID was
# increased from 8-bits to 9-bits
#
# 511 is REALLY reserved ... see DYNAMIC_PMID in libpcp.h
#
RESERVED_DO_NOT_USE	511
#
# ... and nothing greater than 511 is allowed.
