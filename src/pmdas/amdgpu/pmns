amdgpu {
    numcards			AMDGPU:0:0
    cardname			AMDGPU:0:1
    cardid			AMDGPU:0:2
    control
    memory
    gpu
}

amdgpu.memory {
    used			AMDGPU:1:0
    total			AMDGPU:1:1
    free			AMDGPU:1:2
    usedaccum			AMDGPU:1:3
    clock			AMDGPU:1:4
    clock_max			AMDGPU:1:5
}

amdgpu.gpu {
    temperature			AMDGPU:3:0
    load			AMDGPU:3:1
    average_power		AMDGPU:3:2
    clock			AMDGPU:3:3
    clock_max			AMDGPU:3:4
    old_temperature		AMDGPU:3:5
}

amdgpu.control {
    debug			AMDGPU:0:3
}
