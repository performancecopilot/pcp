                'Source: SYSIBMADM.ENV_INST_INFO.SERVICE_LEVEL'],
            self.PM_ID(9, 2) : ['db2.instance.platform',
                pmdaMetric(self.PM_ID(9, 2), c_api.PM_TYPE_STRING,
                    c_api.PM_INDOM_NULL, c_api.PM_SEM_DISCRETE, noUnits),
                {},
                'Db2 instance build level identifier',
                'Db2 build level string from the instance environment,\n'
                'which often encodes CPU architecture (e.g. AMD64).  PLATFORM\n'
                'is not available in SYSIBMADM.ENV_INST_INFO on Db2 v12.\n'
                'Source: SYSIBMADM.ENV_INST_INFO.BLD_LEVEL'],
        }

        # register all the indoms and metrics with the module
        self.setup_indoms()
        self.setup_metrics()

        # bail out early during Install (domain/PMNS generation only)
        if self.install():
            return

        if not ibm_db_available:
            self.log("FATAL: Python 'ibm_db' module is not installed")
            self.log("Install it with: pip install ibm_db")
            sys.exit(1)

        conf_file = os.path.join(pmContext.pmGetConfig('PCP_SYSCONF_DIR'), name, 'db2.conf')

        # parse config for connection settings
        conf_vars = self.config(conf_file, ['connection', 'authentication', 'databases'])
        try:
            self.hostname = conf_vars['connection.hostname']
        except:
            self.hostname = 'localhost'
        try:
            self.port = conf_vars['connection.port']
        except:
            self.port = '50000'
        try:
            self.timeout = int(conf_vars['connection.timeout'])
        except:
            self.timeout = 5

        self.username = ''
        self.password = ''
        try:
            self.username = self.sanitize(conf_vars['authentication.username'])
            self.password = self.sanitize(conf_vars['authentication.password'])
        except:
            pass

        try:
            names = conf_vars['databases.names']
            self.databases = [d for d in names.split() if d]
        except:
            self.databases = []
        if not self.databases:
            self.log("FATAL: no database names configured in [databases] names=")
            sys.exit(1)

        self.log("Connecting to %s, databases: %s, user: %s" %
                 (self.hostname, ' '.join(self.databases), self.username))
        connected = 0
        for dbname in self.databases:
            retries = 0
            while not self.db2_connect(dbname):
                time.sleep(1)
                if retries >= 5:
                    self.log("WARNING: failed to connect to %s after 5 retries" % dbname)
                    break
                retries += 1
            if self.conns.get(dbname) is not None:
                connected += 1
        if connected == 0:
            self.log("FATAL: could not connect to any configured database")
            sys.exit(1)

        # register all the callbacks for PDU handling
        self.set_refresh(self.db2_refresh)
        self.set_instance(self.db2_instance)
        self.set_fetch_callback(self.db2_fetch_callback)
        self.set_label_callback(self.db2_label_callback)
        self.log("Setup complete")

    def db2_connect(self, dbname):
        """ connect to a specific Db2 database """
        self.set_user(pmContext.pmGetConfig('PCP_USER'))
        dsn = ('DATABASE=%s;HOSTNAME=%s;PORT=%s;PROTOCOL=TCPIP;'
               'ConnectTimeout=%s;UID=%s;PWD=%s;' %
               (dbname, self.hostname, self.port, self.timeout,
                self.username, self.password))
        try:
            self.conns[dbname] = ibm_db.connect(dsn, '', '')
        except Exception as error:
            self.error("db2_connect", "connecting to %s/%s as %s: %s" %
                       (self.hostname, dbname, self.username, str(error)))
            self.conns[dbname] = None
            return False
        return True

    def db2_cursor(self, dbname):
        """ return a verified live connection for dbname, reconnecting as needed.

        ibm_db.active() alone is insufficient - it reflects library-side state
        only.  After a Db2 restart the TCP connection may still appear open
        until a query is attempted, so we probe with VALUES(1) first.
        On any failure the connection handle is cleared to force reconnect. """
        connected = False
        while not connected:
            try:
                conn = self.conns.get(dbname)
                if conn is None:
                    raise Exception('Not connected')
                if not ibm_db.active(conn):
                    raise Exception('Connection inactive')
                ibm_db.exec_immediate(conn, 'VALUES(1)')
                connected = True
            except Exception:
                self.log("Lost connection to %s, reconnecting ..." % dbname)
                self.conns[dbname] = None
                if not self.db2_connect(dbname):
                    time.sleep(1)
        return self.conns[dbname]

    def _db2_connection_lost(self, conn, error):
        """ return True when the error indicates the connection is unusable """
        err_str = str(error)
        if 'SQLSTATE=08' in err_str:
            return True
        if conn is None:
            return True
        try:
            return not ibm_db.active(conn)
        except Exception:
            return True

    def table_row_val(self, row, item):
        """ map MON_GET_TABLE columns to metric items; deadlocks not per-table """
        if item == 7:
            return 0
        if item <= 6:
            return row[item + 1]
        return row[item]

    def db2_exec(self, dbname, sql):
        """ execute sql against dbname, return list of row tuples; [] on error.

        Clears the connection handle only on communication failures so a bad
        SQL statement does not force reconnect on every cluster refresh. """
        conn = self.db2_cursor(dbname)
        try:
            stmt = ibm_db.exec_immediate(conn, sql)
            rows = []
            row = ibm_db.fetch_tuple(stmt)
            while row:
                rows.append(row)
                row = ibm_db.fetch_tuple(stmt)
            return rows
        except Exception as error:
            self.error("db2_exec", "%s: query '%s': %s" % (dbname, sql[:60], str(error)))
            if self._db2_connection_lost(conn, error):
                self.conns[dbname] = None
            return []

    def db2_refresh_indom(self, indom):
        """ refresh instance names for the given indom across all databases """
        instances = {}
        if indom == self.INDOM_ID(6):
            # database indom is populated from config, not from SQL
            for dbname in self.databases:
                instances[dbname] = c_int(1)
            self.replace_indom(indom, instances)
            return
        query = self.indoms[indom][self.INDOM_QUERY]
        for dbname in self.databases:
            rows = self.db2_exec(dbname, query)
            for row in rows:
                instname = dbname + '::' + str(row[0]).strip().replace(' ', '_')
                instances[instname] = c_int(1)
        self.replace_indom(indom, instances)

    def db2_instance(self, serial):
        """ called once per instance PDU - only the requested indom is queried """
        self.db2_refresh_indom(self.INDOM_ID(serial))

    def db2_refresh(self, cluster):
        """ called once per cluster per fetch PDU - one SQL query per database per cluster """
        if cluster in self.cluster_db:
            self.db2_refresh_db_scoped(cluster, self.cluster_db,
                                       self.cluster_db_items)
        elif cluster in self.cluster_bp:
            self.db2_refresh_instanced(cluster, self.cluster_bp,
                                       self.cluster_bp_items, self.INDOM_ID(0))
        elif cluster in self.cluster_table:
            self.db2_refresh_instanced(cluster, self.cluster_table,
                                       self.cluster_table_items, self.INDOM_ID(1),
                                       row_val=self.table_row_val)
        elif cluster in self.cluster_wl:
            self.db2_refresh_instanced(cluster, self.cluster_wl,
                                       self.cluster_wl_items, self.INDOM_ID(2))
        elif cluster in self.cluster_ts:
            self.db2_refresh_instanced(cluster, self.cluster_ts,
                                       self.cluster_ts_items, self.INDOM_ID(3))
        elif cluster in self.cluster_conn:
            self.db2_refresh_instanced(cluster, self.cluster_conn,
                                       self.cluster_conn_items, self.INDOM_ID(4))
        elif cluster in self.cluster_latch:
            self.db2_refresh_instanced(cluster, self.cluster_latch,
                                       self.cluster_latch_items, self.INDOM_ID(5))
        elif cluster in self.cluster_log:
            self.db2_refresh_db_scoped(cluster, self.cluster_log,
                                       self.cluster_log_items)
        elif cluster in self.cluster_pkgcache:
            self.db2_refresh_db_scoped(cluster, self.cluster_pkgcache,
                                       self.cluster_pkgcache_items)
        elif cluster in self.cluster_inst:
            self.db2_refresh_singleton(cluster, self.cluster_inst,
                                       self.cluster_inst_items)

    def db2_refresh_singleton(self, cluster, clusters, items):
        """ refresh a cluster returning instance-wide metadata.
            Queries only the first available database — all databases on the
            same Db2 instance share the same version, platform and name.
            Stores results as null-indom values keyed '0'. """
        meta = clusters[cluster]
        for dbname in self.databases:
            rows = self.db2_exec(dbname, meta[self.CLUSTER_QUERY])
            if not rows:
                continue
            row = rows[0]
            for item in range(items):
                pmid = self.PM_ID(cluster, item)
                if pmid in self.metrics:
                    val = row[item] if row[item] is not None else ''
                    self.metrics[pmid][self.METRIC_VALUES]['0'] = val
            break  # instance-wide; one successful query is sufficient

    def db2_refresh_db_scoped(self, cluster, clusters, items):
        """ refresh a cluster returning one aggregate row per database.
            Iterates all configured databases; the database name is the
            instance key in the values dict and in indom 6. """
        meta = clusters[cluster]
        for item in range(items):
            pmid = self.PM_ID(cluster, item)
            if pmid in self.metrics:
                self.metrics[pmid][self.METRIC_VALUES].clear()
        # Pre-populate all configured databases so transient query failures
        # do not remove a database from indom 6 for all db-scoped metrics.
        instances = {dbname: c_int(1) for dbname in self.databases}
        for dbname in self.databases:
            rows = self.db2_exec(dbname, meta[self.CLUSTER_QUERY])
            if not rows:
                continue
            row = rows[0]
            for item in range(items):
                pmid = self.PM_ID(cluster, item)
                if pmid in self.metrics:
                    self.metrics[pmid][self.METRIC_VALUES][dbname] = (
                        row[item] if row[item] is not None else 0)
        self.replace_indom(self.INDOM_ID(6), instances)

    def db2_refresh_instanced(self, cluster, clusters, items, indom, row_val=None):
        """ refresh a cluster returning one row per object instance.
            Iterates all configured databases; instance names are prefixed
            with the database name as dbname/instname. """
        meta = clusters[cluster]
        for item in range(items):
            pmid = self.PM_ID(cluster, item)
            if pmid in self.metrics:
                self.metrics[pmid][self.METRIC_VALUES].clear()
        instances = {}
        for dbname in self.databases:
            rows = self.db2_exec(dbname, meta[self.CLUSTER_QUERY])
            for row in rows:
                instname = dbname + '::' + str(row[0]).strip().replace(' ', '_')
                instances[instname] = c_int(1)
                for item in range(items):
                    pmid = self.PM_ID(cluster, item)
                    if pmid in self.metrics:
                        if row_val is not None:
                            val = row_val(row, item)
                        else:
                            val = row[item + 1]
                        self.metrics[pmid][self.METRIC_VALUES][instname] = (
                            val if val is not None else 0)
        self.replace_indom(indom, instances)

    def db2_fetch_callback(self, cluster, item, inst):
        """ called for each (metric, instance) pair in a fetch PDU """
        pmid = self.PM_ID(cluster, item)
        if pmid not in self.metrics:
            return [c_api.PM_ERR_PMID, 0]
        metric = self.metrics[pmid]
        indom = metric[self.METRIC_META].m_desc.indom
        values = metric[self.METRIC_VALUES]

        try:
            if indom == c_api.PM_INDOM_NULL:
                value = values['0']
            else:
                instname = self.inst_name_lookup(indom, inst)
                if instname is None:
                    return [c_api.PM_ERR_INST, 0]
                value = values[instname]
        except KeyError:
            return [c_api.PM_ERR_VALUE, 0]
        except:
            self.error("db2_fetch_callback",
                       "unexpected error pmid=0x%04x" % pmid)
            return [c_api.PM_ERR_VALUE, 0]

        if value is None:
            if metric[self.METRIC_META].m_desc.type == c_api.PM_TYPE_STRING:
                value = ''
            else:
                value = 0
        return [value, 1]

    def db2_label_callback(self, indom, inst):
        """ return JSON labels for a compound dbname::component instance name.

        Splits the instance name on '::' to expose the database name and
        the per-object component as separate searchable label dimensions.
        Indom 0 (buffer pools):  {"database":"DB","bufferpool":"BP"}
        Indom 1 (tables):        {"database":"DB","table":"SCHEMA.TABLE"}
        Indom 2 (workloads):     {"database":"DB","workload":"WL"}
        Indom 3 (tablespaces):   {"database":"DB","tablespace":"TS"}
        Indom 4 (connections):   {"database":"DB","application":"APP","handle":"H"}
        Indom 5 (latches):       {"database":"DB","latch":"LATCH"}
        Indom 6 (databases):     {"database":"DB"}
        """
        instname = self.inst_name_lookup(indom, inst)
        if instname is None:
            return '{}'
        parts = instname.split('::')
        if not parts:
            return '{}'

        db = parts[0]
        label_keys = {
            self.INDOM_ID(0): 'bufferpool',
            self.INDOM_ID(1): 'table',
            self.INDOM_ID(2): 'workload',
            self.INDOM_ID(3): 'tablespace',
            self.INDOM_ID(5): 'latch',
        }

        result = {'database': db}
        if indom == self.INDOM_ID(4) and len(parts) >= 3:
            result['application'] = parts[1]
            result['handle'] = parts[2]
        elif indom in label_keys and len(parts) >= 2:
            result[label_keys[indom]] = parts[1]
        return json.dumps(result, separators=(',', ':'))

    def setup_indoms(self):
        """ register all indom objects with help text """
        for data in self.indoms.values():
            oneline = data[self.INDOM_ONE] if len(data) > self.INDOM_ONE else ''
            text    = data[self.INDOM_TEXT] if len(data) > self.INDOM_TEXT else ''
            self.add_indom(data[self.INDOM_META], oneline, text)

    def setup_metrics(self):
        """ register all metric objects with one-line and long help text """
        for metric in self.metrics.values():
            oneline = metric[self.METRIC_ONELINE] if len(metric) > self.METRIC_ONELINE else ''
            text    = metric[self.METRIC_TEXT]    if len(metric) > self.METRIC_TEXT    else ''
            self.add_metric(metric[self.METRIC_NAME],
                            metric[self.METRIC_META],
                            oneline, text)

    def config(self, filename, sections):
        """ parse ini-style config file, raise on missing section """
        parser = configparser.RawConfigParser()
        parser.read(filename)
        params = {}
        for section in sections:
            if parser.has_section(section):
                for param in parser.items(section):
                    params[section + '.' + param[0]] = param[1]
            else:
                raise NameError('Section %s not found in %s' % (section, filename))
        return params

    def install(self):
        """ return True when running under Install for domain/PMNS generation """
        if 'PCP_PYTHON_DOMAIN' in os.environ:
            return True
        elif 'PCP_PYTHON_PMNS' in os.environ:
            return True
        return False

    def error(self, function, message):
        """ log an error with function context """
        self.err(function + ': ' + message)

    def debug(self, function, message=''):
        """ log a debug message when verbose is set """
        if self.verbose:
            if message:
                self.dbg(function + ': ' + message)
            else:
                self.dbg(function)

if __name__ == '__main__':
    pmda = DB2PMDA('db2', 42)
    pmda.run()
