""" PCP IBM Db2 Performance Metrics Domain Agent """

# pylint: disable=bad-continuation,line-too-long,too-many-lines,bare-except
# pylint: disable=consider-using-dict-items

import json
import os
import sys
import time
try:
    import configparser
except ImportError:
    import ConfigParser as configparser
from ctypes import c_int
from pcp.pmapi import pmUnits, pmContext
from pcp.pmda import PMDA, pmdaMetric, pmdaIndom
import cpmapi as c_api
try:
    import ibm_db
    ibm_db_available = True
except ImportError:
    ibm_db = None
    ibm_db_available = False


class DB2PMDA(PMDA):
    """
    PMDA class for IBM Db2 performance metrics.

    Query strategy: each cluster maps to exactly one MON_GET_* SQL call that
    returns all columns for all instances in a single round-trip.  PCP's
    cluster-based refresh mechanism ensures only the clusters whose metrics
    are actually requested are ever queried.  A fetch of a single metric
    issues one query; a fetch of all metrics issues one query per cluster.
    No per-metric queries are issued.
    """

    def PM_ID(self, cluster, item):
        """ pmid from PMDA domain, cluster and item """
        return PMDA.pmid(cluster, item)

    def INDOM_ID(self, serial):
        """ indom id from PMDA domain and serial """
        return PMDA.indom(serial)

    def sanitize(self, string):
        """ escape special characters for DSN connection strings """
        if string is None:
            return ''
        elif not isinstance(string, str):
            string = str(string)
        string = string.replace("\\", "\\\\")
        string = string.replace("'", "\\'")
        string = string.replace(";", "\\;")
        return string

    def __init__(self, name, domain):
        """ constructor """
        PMDA.__init__(self, name, domain)
        self.connect_pmcd()
        self.verbose = False
        self.conns = {}
        self.databases = []
        self.debug("__init__")

        # InDom dictionary entries: [pmdaIndom, instance_query, oneline, text]
        self.INDOM_META   = 0
        self.INDOM_QUERY  = 1
        self.INDOM_ONE    = 2
        self.INDOM_TEXT   = 3
        self.indoms = {
            self.INDOM_ID(0) : [pmdaIndom(self.INDOM_ID(0), {}),
                'SELECT DISTINCT BP_NAME '
                'FROM TABLE(MON_GET_BUFFERPOOL(NULL,-1)) '
                'WHERE BP_NAME IS NOT NULL',
                'Buffer pool name',
                'Each instance represents one Db2 buffer pool by name.\n'
                'Buffer pools are areas of memory used to cache database\n'
                'pages for table data, indexes, and column-organised data.'],
            self.INDOM_ID(1) : [pmdaIndom(self.INDOM_ID(1), {}),
                "SELECT DISTINCT RTRIM(TABSCHEMA)||'.'||RTRIM(TABNAME) "
                'FROM TABLE(MON_GET_TABLE(NULL,NULL,-1)) '
                "WHERE TABSCHEMA NOT LIKE 'SYS%'",
                'Table name (schema.table)',
                'Each instance represents one user table in the database,\n'
                'identified as schema.table.  System tables (SYS* schemas)\n'
                'are excluded.  Source: MON_GET_TABLE.'],
            self.INDOM_ID(2) : [pmdaIndom(self.INDOM_ID(2), {}),
                'SELECT DISTINCT WORKLOAD_NAME '
                'FROM TABLE(MON_GET_WORKLOAD(NULL,-1)) '
                'WHERE WORKLOAD_NAME IS NOT NULL',
                'Workload name',
                'Each instance represents a Db2 workload definition.\n'
                'Workloads classify incoming connections based on attributes\n'
                'such as application name or IP address.  Source: MON_GET_WORKLOAD.'],
            self.INDOM_ID(3) : [pmdaIndom(self.INDOM_ID(3), {}),
                'SELECT DISTINCT TBSP_NAME '
                'FROM TABLE(MON_GET_TABLESPACE(NULL,-1)) '
                'WHERE TBSP_NAME IS NOT NULL',
                'Tablespace name',
                'Each instance represents one Db2 tablespace.\n'
                'Tablespaces are logical storage units that group related\n'
                'table and index data.  Source: MON_GET_TABLESPACE.'],
            self.INDOM_ID(4) : [pmdaIndom(self.INDOM_ID(4), {}),
                "SELECT DISTINCT "
                "COALESCE(APPLICATION_NAME,'unknown')||'::'||CHAR(APPLICATION_HANDLE) "
                'FROM TABLE(MON_GET_CONNECTION(NULL,-1))',
                'Connection identifier (appname::handle)',
                'Each instance represents one active application connection,\n'
                'identified as application_name/application_handle.  Instances\n'
                'are transient and change as connections are established and\n'
                'dropped.  Source: MON_GET_CONNECTION.'],
            self.INDOM_ID(5) : [pmdaIndom(self.INDOM_ID(5), {}),
                'SELECT DISTINCT LATCH_NAME '
                'FROM TABLE(MON_GET_EXTENDED_LATCH_WAIT(NULL)) '
                'WHERE LATCH_NAME IS NOT NULL '
                'AND TOTAL_EXTENDED_LATCH_WAITS > 0',
                'Latch name',
                'Each instance represents one internal Db2 latch type that\n'
                'has experienced extended wait events.  High latch contention\n'
                'indicates internal memory or I/O bottlenecks.\n'
                'Source: MON_GET_EXTENDED_LATCH_WAIT.'],
            self.INDOM_ID(6) : [pmdaIndom(self.INDOM_ID(6), {}),
                None,
                'Database name',
                'Each instance represents one monitored Db2 database.\n'
                'Database names are taken from the [databases] section of\n'
                'the configuration file.  All db2.database.*, db2.log.*\n'
                'and db2.pkg_cache.* metrics are instanced on this domain.'],
        }

        # Cluster metadata: [indom_id, SQL query]
        # Null-indom clusters: query returns a single aggregate row; column
        # positions map sequentially to item numbers 0..N-1.
        # Instanced clusters: first SELECT column is the instance name;
        # subsequent columns map to item numbers 0..N-1.
        self.CLUSTER_INDOM = 0
        self.CLUSTER_QUERY = 1

        # Cluster 0: MON_GET_DATABASE — database-wide aggregate (null indom)
        # 27 items (columns 0-26 in SELECT order).
        self.cluster_db_items = 27
        self.cluster_db = {
            0: [c_api.PM_INDOM_NULL,
                'SELECT '
                'TOTAL_APP_COMMITS,'           # 0
                'TOTAL_APP_ROLLBACKS,'         # 1
                'ROWS_READ,'                   # 2
                'ROWS_MODIFIED,'               # 3
                'ROWS_RETURNED,'               # 4
                'SORT_OVERFLOWS,'              # 5
                'TOTAL_CPU_TIME,'              # 6  microseconds
                'TOTAL_WAIT_TIME,'             # 7  microseconds
                'TOTAL_SECTION_SORT_TIME,'     # 8  microseconds
                'LOCK_WAITS,'                  # 9
                'LOCK_WAIT_TIME,'              # 10 milliseconds
                'DEADLOCKS,'                   # 11
                'LOCK_ESCALS,'                 # 12
                'LOCK_TIMEOUTS,'               # 13
                'NUM_LOCKS_HELD,'              # 14 gauge
                'APPLS_CUR_CONS,'              # 15 gauge
                'APPLS_IN_DB2,'                # 16 gauge
                'CONNECTIONS_TOP,'             # 17 gauge (peak)
                'ACT_COMPLETED_TOTAL,'         # 18 (STMTS_COMPLETED on older Db2)
                'TOTAL_SORTS,'                 # 19
                'PKG_CACHE_LOOKUPS,'           # 20
                'PKG_CACHE_INSERTS,'           # 21
                'PKG_CACHE_NUM_OVERFLOWS,'     # 22
                'DIRECT_READS,'                # 23
                'DIRECT_READ_TIME,'            # 24 microseconds
                'DIRECT_WRITES,'               # 25
                'DIRECT_WRITE_TIME '           # 26 microseconds
                'FROM TABLE(MON_GET_DATABASE(-1))'],
        }

        # Cluster 1: MON_GET_BUFFERPOOL — per buffer pool (indom 0)
        # 14 items; first SELECT column is BP_NAME (instance), then 14 values.
        self.cluster_bp_items = 12
        self.cluster_bp = {
            1: [self.INDOM_ID(0),
                'SELECT BP_NAME,'
                'POOL_DATA_L_READS,'           # 0
                'POOL_DATA_P_READS,'           # 1
                'POOL_DATA_WRITES,'            # 2
                'POOL_ASYNC_DATA_READS,'       # 3
                'POOL_INDEX_L_READS,'          # 4
                'POOL_INDEX_P_READS,'          # 5
                'POOL_INDEX_WRITES,'           # 6
                'POOL_ASYNC_INDEX_READS,'      # 7
                'POOL_COL_L_READS,'            # 8
                'POOL_COL_P_READS,'            # 9
                'POOL_READ_TIME,'              # 10 milliseconds
                'POOL_WRITE_TIME '             # 11 milliseconds
                'FROM TABLE(MON_GET_BUFFERPOOL(NULL,-1))'],
        }

        # Cluster 2: MON_GET_TABLE — per user table (indom 1)
        # 10 items; first SELECT column is schema.table (instance).
        self.cluster_table_items = 10
        self.cluster_table = {
            2: [self.INDOM_ID(1),
                "SELECT RTRIM(TABSCHEMA)||'.'||RTRIM(TABNAME),"
                'ROWS_READ,'                   # 0
                'ROWS_INSERTED,'               # 1
                'ROWS_UPDATED,'                # 2
                'ROWS_DELETED,'                # 3
                'LOCK_WAITS,'                  # 4
                'LOCK_WAIT_TIME,'              # 5 milliseconds
                'LOCK_ESCALS,'                 # 6
                'OVERFLOW_ACCESSES,'           # 7 (item 7 deadlocks not in MON_GET_TABLE)
                'TABLE_SCANS '                 # 8
                'FROM TABLE(MON_GET_TABLE(NULL,NULL,-1)) '
                "WHERE TABSCHEMA NOT LIKE 'SYS%'"],
        }

        # Cluster 3: MON_GET_WORKLOAD — per workload (indom 2)
        # 8 items; first SELECT column is WORKLOAD_NAME (instance).
        self.cluster_wl_items = 8
        self.cluster_wl = {
            3: [self.INDOM_ID(2),
                'SELECT WORKLOAD_NAME,'
                'ROWS_READ,'                   # 0
                'ROWS_RETURNED,'               # 1
                'ROWS_MODIFIED,'               # 2
                'TOTAL_CPU_TIME,'              # 3 microseconds
                'TOTAL_APP_COMMITS,'           # 4
                'TOTAL_APP_ROLLBACKS,'         # 5
                'LOCK_WAITS,'                  # 6
                'LOCK_WAIT_TIME '              # 7 milliseconds
                'FROM TABLE(MON_GET_WORKLOAD(NULL,-1))'],
        }

        # Cluster 4: MON_GET_TABLESPACE — per tablespace (indom 3)
        # 15 items; first SELECT column is TBSP_NAME (instance).
        self.cluster_ts_items = 15
        self.cluster_ts = {
            4: [self.INDOM_ID(3),
                'SELECT TBSP_NAME,'
                'POOL_DATA_L_READS,'           # 0
                'POOL_DATA_P_READS,'           # 1
                'POOL_DATA_WRITES,'            # 2
                'POOL_ASYNC_DATA_READS,'       # 3
                'POOL_ASYNC_DATA_WRITES,'      # 4
                'POOL_INDEX_L_READS,'          # 5
                'POOL_INDEX_P_READS,'          # 6
                'POOL_INDEX_WRITES,'           # 7
                'POOL_ASYNC_INDEX_READS,'      # 8
                'POOL_ASYNC_INDEX_WRITES,'     # 9
                'DIRECT_READS,'                # 10
                'DIRECT_READ_TIME,'            # 11 microseconds
                'DIRECT_WRITES,'               # 12
                'DIRECT_WRITE_TIME,'           # 13 microseconds
                'UNREAD_PREFETCH_PAGES '       # 14
                'FROM TABLE(MON_GET_TABLESPACE(NULL,-1))'],
        }

        # Cluster 5: MON_GET_CONNECTION — per active connection (indom 4)
        # 10 items; first SELECT column is appname::handle (instance).
        self.cluster_conn_items = 10
        self.cluster_conn = {
            5: [self.INDOM_ID(4),
                "SELECT COALESCE(APPLICATION_NAME,'unknown')||'::'||CHAR(APPLICATION_HANDLE),"
                'TOTAL_CPU_TIME,'              # 0 microseconds
                'ROWS_READ,'                   # 1
                'ROWS_MODIFIED,'               # 2
                'ROWS_RETURNED,'               # 3
                'TOTAL_APP_COMMITS,'           # 4
                'TOTAL_APP_ROLLBACKS,'         # 5
                'LOCK_WAITS,'                  # 6
                'LOCK_WAIT_TIME,'              # 7 milliseconds
                'DEADLOCKS,'                   # 8
                'LOCK_ESCALS '                 # 9
                'FROM TABLE(MON_GET_CONNECTION(NULL,-1))'],
        }

        # Cluster 6: MON_GET_EXTENDED_LATCH_WAIT — per latch type (indom 5)
        # 2 items; first SELECT column is LATCH_NAME (instance).
        # Filtered to latches with at least one extended wait event.
        self.cluster_latch_items = 2
        self.cluster_latch = {
            6: [self.INDOM_ID(5),
                'SELECT LATCH_NAME,'
                'TOTAL_EXTENDED_LATCH_WAIT_TIME,'  # 0 microseconds
                'TOTAL_EXTENDED_LATCH_WAITS '      # 1
                'FROM TABLE(MON_GET_EXTENDED_LATCH_WAIT(NULL)) '
                'WHERE TOTAL_EXTENDED_LATCH_WAITS > 0'],
        }

        # Cluster 9: SYSIBMADM.ENV_INST_INFO — instance metadata (null indom, discrete)
        # 3 items.  Queried from the first available database connection since
        # instance attributes (version, platform, name) are shared across all
        # databases on the same Db2 instance.  PM_SEM_DISCRETE: log-once.
        self.cluster_inst_items = 3
        self.cluster_inst = {
            9: [c_api.PM_INDOM_NULL,
                'SELECT INST_NAME, SERVICE_LEVEL, BLD_LEVEL '
                'FROM SYSIBMADM.ENV_INST_INFO '
                'FETCH FIRST ROW ONLY'],
        }

        # Cluster 7: MON_GET_TRANSACTION_LOG — log I/O aggregate (null indom)
        # 10 items.  Function takes a single member INTEGER parameter; -1
        # selects all database members.
        self.cluster_log_items = 10
        self.cluster_log = {
            7: [c_api.PM_INDOM_NULL,
                'SELECT '
                'LOG_WRITES,'                       # 0
                'LOG_WRITE_TIME,'                   # 1 microseconds
                'LOG_READS,'                        # 2
                'LOG_READ_TIME,'                    # 3 microseconds
                'NUM_LOG_WRITE_IO,'                 # 4
                'NUM_LOG_READ_IO,'                  # 5
                'NUM_LOG_DATA_FOUND_IN_BUFFER,'     # 6
                'NUM_LOG_BUFFER_FULL,'              # 7
                'TOTAL_LOG_USED / 1024,'            # 8 gauge (bytes -> KB)
                'TOTAL_LOG_AVAILABLE / 1024 '       # 9 gauge (bytes -> KB)
                'FROM TABLE(MON_GET_TRANSACTION_LOG(-1))'],
        }

        # Cluster 8: MON_GET_PKG_CACHE_STMT aggregate (null indom)
        # Summarises the entire package cache without a per-statement indom.
        # 6 items.
        self.cluster_pkgcache_items = 6
        self.cluster_pkgcache = {
            8: [c_api.PM_INDOM_NULL,
                'SELECT '
                'COUNT(*),'                         # 0 gauge
                'SUM(NUM_EXECUTIONS),'              # 1
                'SUM(TOTAL_CPU_TIME),'              # 2 microseconds
                'SUM(ROWS_READ),'                   # 3
                'SUM(TOTAL_SORTS),'                  # 4
                'SUM(SORT_OVERFLOWS) '              # 5
                'FROM TABLE(MON_GET_PKG_CACHE_STMT(NULL,NULL,NULL,-1))'],
        }

        # Metric table: PMID -> [name, pmdaMetric, values_dict, oneline, text]
        self.METRIC_NAME    = 0
        self.METRIC_META    = 1
        self.METRIC_VALUES  = 2
        self.METRIC_ONELINE = 3
        self.METRIC_TEXT    = 4

        noUnits    = pmUnits(0, 0, 0, 0, 0, 0)
        usecUnits  = pmUnits(0, 1, 0, 0, c_api.PM_TIME_USEC, 0)
        msecUnits  = pmUnits(0, 1, 0, 0, c_api.PM_TIME_MSEC, 0)
        countUnits = pmUnits(0, 0, 1, 0, 0, c_api.PM_COUNT_ONE)
        kbyteUnits = pmUnits(1, 0, 0, c_api.PM_SPACE_KBYTE, 0, 0)

        self.metrics = {

            # -----------------------------------------------------------
            # Cluster 0: MON_GET_DATABASE  (null indom, 27 items)
            # -----------------------------------------------------------
            self.PM_ID(0, 0) : ['db2.database.commits',
                pmdaMetric(self.PM_ID(0, 0), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, countUnits),
                {},
                'Total application commits',
                'Cumulative number of units of work that have been committed\n'
                'since the database was activated.\n'
                'Source: MON_GET_DATABASE.TOTAL_APP_COMMITS'],
            self.PM_ID(0, 1) : ['db2.database.rollbacks',
                pmdaMetric(self.PM_ID(0, 1), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, countUnits),
                {},
                'Total application rollbacks',
                'Cumulative number of units of work that have been rolled back\n'
                'since the database was activated.\n'
                'Source: MON_GET_DATABASE.TOTAL_APP_ROLLBACKS'],
            self.PM_ID(0, 2) : ['db2.database.rows_read',
                pmdaMetric(self.PM_ID(0, 2), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, countUnits),
                {},
                'Total rows read',
                'Cumulative number of rows read by all database operations.\n'
                'High values relative to rows_returned indicate poorly tuned\n'
                'queries performing excessive table scans.\n'
                'Source: MON_GET_DATABASE.ROWS_READ'],
            self.PM_ID(0, 3) : ['db2.database.rows_modified',
                pmdaMetric(self.PM_ID(0, 3), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, countUnits),
                {},
                'Total rows modified (inserted, updated, deleted)',
                'Cumulative number of rows inserted, updated, and deleted\n'
                'since the database was activated.\n'
                'Source: MON_GET_DATABASE.ROWS_MODIFIED'],
            self.PM_ID(0, 4) : ['db2.database.rows_returned',
                pmdaMetric(self.PM_ID(0, 4), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, countUnits),
                {},
                'Total rows returned to applications',
                'Cumulative number of rows returned to applications.\n'
                'Compare with rows_read to assess query efficiency.\n'
                'Source: MON_GET_DATABASE.ROWS_RETURNED'],
            self.PM_ID(0, 5) : ['db2.database.sort_overflows',
                pmdaMetric(self.PM_ID(0, 5), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, countUnits),
                {},
                'Total sort overflows',
                'Cumulative number of sorts that ran out of sort heap memory\n'
                'and spilled to temporary tablespace on disk.  High values\n'
                'indicate the sort heap (SORTHEAP) is undersized.\n'
                'Source: MON_GET_DATABASE.SORT_OVERFLOWS'],
            self.PM_ID(0, 6) : ['db2.database.total_cpu_time',
                pmdaMetric(self.PM_ID(0, 6), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, usecUnits),
                {},
                'Total CPU time consumed by database activity (microseconds)',
                'Cumulative CPU time (user + system) consumed by all database\n'
                'activity since activation, in microseconds.\n'
                'Source: MON_GET_DATABASE.TOTAL_CPU_TIME'],
            self.PM_ID(0, 7) : ['db2.database.total_wait_time',
                pmdaMetric(self.PM_ID(0, 7), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, usecUnits),
                {},
                'Total time applications spent waiting (microseconds)',
                'Cumulative time all applications spent waiting for any\n'
                'database resource (locks, I/O, latches, etc.) since\n'
                'activation, in microseconds.\n'
                'Source: MON_GET_DATABASE.TOTAL_WAIT_TIME'],
            self.PM_ID(0, 8) : ['db2.database.total_section_sort_time',
                pmdaMetric(self.PM_ID(0, 8), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, usecUnits),
                {},
                'Total time spent in section sorts (microseconds)',
                'Cumulative time consumed by all section sort operations since\n'
                'activation, in microseconds.\n'
                'Source: MON_GET_DATABASE.TOTAL_SECTION_SORT_TIME'],
            self.PM_ID(0, 9) : ['db2.database.lock_waits',
                pmdaMetric(self.PM_ID(0, 9), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, countUnits),
                {},
                'Total lock wait events',
                'Cumulative number of times applications had to wait for a\n'
                'lock since activation.  Use with lock_wait_time to compute\n'
                'average lock wait duration.\n'
                'Source: MON_GET_DATABASE.LOCK_WAITS'],
            self.PM_ID(0, 10) : ['db2.database.lock_wait_time',
                pmdaMetric(self.PM_ID(0, 10), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, msecUnits),
                {},
                'Total time applications spent waiting for locks (milliseconds)',
                'Cumulative time all applications spent waiting to acquire\n'
                'locks since activation, in milliseconds.\n'
                'Source: MON_GET_DATABASE.LOCK_WAIT_TIME'],
            self.PM_ID(0, 11) : ['db2.database.deadlocks',
                pmdaMetric(self.PM_ID(0, 11), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, countUnits),
                {},
                'Total deadlocks detected',
                'Cumulative number of deadlocks that were detected and\n'
                'resolved by rolling back one of the conflicting transactions.\n'
                'Source: MON_GET_DATABASE.DEADLOCKS'],
            self.PM_ID(0, 12) : ['db2.database.lock_escalations',
                pmdaMetric(self.PM_ID(0, 12), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, countUnits),
                {},
                'Total lock escalations',
                'Cumulative number of times row locks were escalated to table\n'
                'locks to reduce the lock list memory footprint.  Escalations\n'
                'degrade concurrency significantly.\n'
                'Source: MON_GET_DATABASE.LOCK_ESCALS'],
            self.PM_ID(0, 13) : ['db2.database.lock_timeouts',
                pmdaMetric(self.PM_ID(0, 13), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, countUnits),
                {},
                'Total lock timeout events',
                'Cumulative number of times a lock request timed out rather\n'
                'than waiting (controlled by LOCKTIMEOUT database config).\n'
                'Source: MON_GET_DATABASE.LOCK_TIMEOUTS'],
            self.PM_ID(0, 14) : ['db2.database.num_locks_held',
                pmdaMetric(self.PM_ID(0, 14), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_INSTANT, countUnits),
                {},
                'Current number of locks held',
                'Instantaneous count of locks currently held by all\n'
                'applications connected to the database.\n'
                'Source: MON_GET_DATABASE.NUM_LOCKS_HELD'],
            self.PM_ID(0, 15) : ['db2.database.active_connections',
                pmdaMetric(self.PM_ID(0, 15), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_INSTANT, countUnits),
                {},
                'Current number of connected applications',
                'Instantaneous count of applications currently connected to\n'
                'the database, including both active and idle connections.\n'
                'Source: MON_GET_DATABASE.APPLS_CUR_CONS'],
            self.PM_ID(0, 16) : ['db2.database.appls_in_db2',
                pmdaMetric(self.PM_ID(0, 16), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_INSTANT, countUnits),
                {},
                'Current number of applications actively executing in Db2',
                'Instantaneous count of applications that are currently\n'
                'processing a request inside the Db2 engine (subset of\n'
                'active_connections).\n'
                'Source: MON_GET_DATABASE.APPLS_IN_DB2'],
            self.PM_ID(0, 17) : ['db2.database.connections_top',
                pmdaMetric(self.PM_ID(0, 17), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_INSTANT, countUnits),
                {},
                'Peak number of simultaneous connections since last reset',
                'Maximum number of applications connected at the same time\n'
                'since the database was last activated or statistics reset.\n'
                'Source: MON_GET_DATABASE.CONNECTIONS_TOP'],
            self.PM_ID(0, 18) : ['db2.database.stmts_completed',
                pmdaMetric(self.PM_ID(0, 18), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, countUnits),
                {},
                'Total SQL statements completed',
                'Cumulative number of SQL and XQuery statements that have\n'
                'completed execution since the database was activated.\n'
                'Source: MON_GET_DATABASE.ACT_COMPLETED_TOTAL'],
            self.PM_ID(0, 19) : ['db2.database.total_sorts',
                pmdaMetric(self.PM_ID(0, 19), c_api.PM_TYPE_U64,
                    self.INDOM_ID(6), c_api.PM_SEM_COUNTER, countUnits),
                {},
