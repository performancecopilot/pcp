                pmdaMetric(self.PM_ID(9, 0), c_api.PM_TYPE_STRING,
                    c_api.PM_INDOM_NULL, c_api.PM_SEM_DISCRETE, noUnits),
                {},
                'Db2 instance name',
                'Name of the Db2 instance (database manager instance) to\n'
                'which the monitored databases belong.\n'
                'Source: SYSIBMADM.ENV_INST_INFO.INST_NAME'],
            self.PM_ID(9, 1) : ['db2.instance.version',
                pmdaMetric(self.PM_ID(9, 1), c_api.PM_TYPE_STRING,
                    c_api.PM_INDOM_NULL, c_api.PM_SEM_DISCRETE, noUnits),
                {},
                'Db2 instance service level (version string)',
                'Full Db2 release and service level string, for example\n'
                '"DB2 v11.5.8.0 s2309091300".  Useful as archive context\n'
